# Groq API Configuration
# Get your API key from https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# HuggingFace API (Optional)
# Only needed if using HuggingFace's inference API for embeddings
# Get your token from https://huggingface.co/settings/tokens
HF_API_KEY=your_huggingface_api_key_here

# Note: Copy this file to .env and fill in your actual credentials
# Never commit .env to version control - it contains sensitive information
